---
interface Props {
  phone: string;
}
const { phone } = Astro.props;
---

<header class="header" role="banner">
  <nav class="container header-inner" aria-label="Navegación principal">
    <a href="#inicio" class="logo-link" aria-label="USA Fitness - Inicio">
      <img src="/usafitness.svg" alt="USA Fitness logo" class="logo" width="200" height="42" />
    </a>
    <a href={`tel:${phone}`} class="header-phone btn btn-primary" aria-label={`Llamar al ${phone}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      Llámanos
    </a>
  </nav>
</header>

<style>
  .header {
    background: var(--color-bg);
    height: 70px;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .logo-link {
    display: flex;
    align-items: center;
    height: 100%;
    padding: 14px 0;
  }

  .logo {
    height: 100%;
    width: auto;
    max-width: 200px;
    object-fit: contain;
  }

  .header-phone {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .logo {
      max-width: 150px;
    }

    .header-phone {
      padding: 0.4rem 0.8rem;
      font-size: 0.8rem;
    }
  }
</style>
