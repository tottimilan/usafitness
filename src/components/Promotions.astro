---
interface Props {
  phone: string;
}
const { phone } = Astro.props;

const promos = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
    title: "TARIFA VIP",
    text: "Hasta 10% de descuento por hacerte socio."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    title: "DESCUENTO FUNCIONARIO",
    text: "Hasta 15% extra de descuento funcionario (policía, bombero)"
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>`,
    title: "DESCUENTO CUMPLEAÑOS",
    text: "Hasta 20% de descuento en tu cumpleaños."
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"/><circle cx="6.5" cy="6.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>`,
    title: "CUPÓN 5 €",
    text: "Descuento extra a partir de 49,90€"
  }
];
---

<section class="promotions section" id="promociones">
  <div class="container">
    <h2 class="section-title">¡Aprovecha nuestras promociones!</h2>
    <div class="promos-grid">
      {promos.map((promo) => (
        <div class="promo-card">
          <div class="promo-icon" set:html={promo.icon} />
          <h3 class="promo-title">{promo.title}</h3>
          <p class="promo-text">{promo.text}</p>
        </div>
      ))}
    </div>
    <div class="promos-cta">
      <a href={`tel:${phone}`} class="btn btn-primary">
        Llámanos y Te Contamos
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .promotions {
    background: var(--color-bg-alt);
  }

  .promos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .promo-card {
    text-align: center;
    padding: 1.75rem 1.25rem;
    border-radius: 12px;
    background: var(--color-bg);
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    border-top: 3px solid var(--color-cta);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .promo-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.1);
  }

  .promo-icon {
    color: var(--color-cta);
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
  }

  .promo-title {
    font-size: 1rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    letter-spacing: 0.5px;
  }

  .promo-text {
    font-size: 0.88rem;
    color: var(--color-text-light);
    line-height: 1.5;
  }

  .promos-cta {
    text-align: center;
  }

  @media (max-width: 768px) {
    .promos-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }
  }

  @media (max-width: 480px) {
    .promos-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }
</style>
