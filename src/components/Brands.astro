---
const brands = [
  { name: 'Quamtrax', file: 'quamtrax.png' },
  { name: 'Applied Nutrition', file: 'applied.png' },
  { name: 'Zoomad Labs', file: 'zoomad.png' },
  { name: 'Cellucor', file: 'cellucor.jpg' },
  { name: 'MuscleTech', file: 'muscletech.png' },
  { name: 'Optimum Nutrition', file: 'optimum.png' },
  { name: 'Amix', file: 'amix.png' },
  { name: 'Nutrex', file: 'nutrex.png' },
];
---

<section class="brands section" aria-label="Logos marcas principales">
  <div class="brands-viewport">
    <div class="brands-track">
      {brands.map((brand) => (
        <div class="brand-item">
          <img
            src={`/brands/${brand.file}`}
            alt={`Logo ${brand.name}`}
            loading="lazy"
            draggable="false"
            width="180"
            height="65"
          />
        </div>
      ))}
      {brands.map((brand) => (
        <div class="brand-item" aria-hidden="true">
          <img
            src={`/brands/${brand.file}`}
            alt=""
            loading="lazy"
            draggable="false"
            width="180"
            height="65"
          />
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .brands {
    padding: 2.5rem 0;
    border-top: 1px solid #eee;
    border-bottom: 1px solid #eee;
    overflow: hidden;
  }

  .brands-viewport {
    position: relative;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }

  .brands-track {
    display: flex;
    gap: 3rem;
    width: max-content;
    animation: scroll-brands 30s linear infinite;
  }

  .brands-track:hover {
    animation-play-state: paused;
  }

  .brand-item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .brand-item img {
    height: 65px;
    width: auto;
    max-width: 180px;
    object-fit: contain;
    user-select: none;
    pointer-events: none;
    transition: transform 0.2s;
  }

  .brand-item:hover img {
    transform: scale(1.05);
  }

  @keyframes scroll-brands {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .brands-track {
      gap: 2rem;
      animation-duration: 20s;
    }

    .brand-item img {
      height: 50px;
      max-width: 140px;
    }
  }
</style>
