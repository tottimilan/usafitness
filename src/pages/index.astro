---
export const prerender = true;

import storesData from '@/data/stores.json';
const stores = storesData.stores;
import '@/styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/usafitness.svg" />
    <title>USAFitness - Tiendas</title>
  </head>
  <body>
    <div class="index-page">
      <img src="/usafitness.svg" alt="USA Fitness" class="index-logo" width="180" />
      <h1>USAFitness Tiendas</h1>
      <p>Selecciona una tienda:</p>
      <div class="store-links">
        {stores.map((store) => (
          <a href={`/${store.slug}`} class="btn btn-primary store-link">
            {store.name}
          </a>
        ))}
      </div>
    </div>
  </body>
</html>

<style>
  .index-page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 2rem;
    gap: 1rem;
  }

  .index-logo {
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 2rem;
  }

  p {
    color: var(--color-text-light);
    margin-bottom: 0.5rem;
  }

  .store-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .store-link {
    min-width: 280px;
    justify-content: center;
  }
</style>
