---
interface Props {
  name: string;
  domain: string;
  title: string;
  metaDescription: string;
  location: string;
  phone: string;
  phoneDisplay: string;
  schedule: string;
  slug: string;
  streetAddress?: string;
  postalCode?: string;
  geo?: { lat: number; lng: number };
  reviewCount?: number;
  avgRating?: number;
}

const {
  name, domain, title, metaDescription, location,
  phone, phoneDisplay, schedule, slug,
  streetAddress = '', postalCode = '',
  geo, reviewCount = 3, avgRating = 5
} = Astro.props;

const pageTitle = `${name} | Nutrición Deportiva en ${location}`;
const canonicalUrl = `https://${domain}/`;
const ogImage = `/photos/${slug}/hero.jpg`;

function parseScheduleToSchema(scheduleText: string) {
  const specs: any[] = [];
  const lines = scheduleText.split('\n');
  for (const line of lines) {
    if (line.toLowerCase().includes('lunes a viernes')) {
      const timeMatch = line.match(/(\d{1,2}:\d{2})\s*a\s*(\d{1,2}:\d{2})/);
      if (timeMatch) {
        specs.push({
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": timeMatch[1],
          "closes": timeMatch[2]
        });
      }
    }
    if (line.toLowerCase().includes('sábado')) {
      const timeMatch = line.match(/(\d{1,2}:\d{2})\s*[a–-]\s*(\d{1,2}:\d{2})/);
      if (timeMatch) {
        specs.push({
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Saturday"],
          "opens": timeMatch[1],
          "closes": timeMatch[2]
        });
      }
    }
    if (line.toLowerCase().includes('domingo')) {
      const timeMatch = line.match(/(\d{1,2}:\d{2})\s*[a–-]\s*(\d{1,2}:\d{2})/);
      if (timeMatch) {
        specs.push({
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Sunday"],
          "opens": timeMatch[1],
          "closes": timeMatch[2]
        });
      }
    }
    if (line.toLowerCase().includes('lunes a sábado')) {
      const timeMatch = line.match(/(\d{1,2}:\d{2})\s*[a–-]\s*(\d{1,2}:\d{2})/);
      if (timeMatch) {
        specs.push({
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": timeMatch[1],
          "closes": timeMatch[2]
        });
      }
    }
    if (line.toLowerCase().includes('lunes a domingo')) {
      const timeMatch = line.match(/(\d{1,2}:\d{2})\s*[a–-]\s*(\d{1,2}:\d{2})/);
      if (timeMatch) {
        specs.push({
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
          "opens": timeMatch[1],
          "closes": timeMatch[2]
        });
      }
    }
  }
  return specs.length > 0 ? specs : undefined;
}

const openingHours = parseScheduleToSchema(schedule);

const structuredData: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": name,
  "description": metaDescription,
  "url": canonicalUrl,
  "telephone": phone,
  "image": `https://${domain}${ogImage}`,
  "priceRange": "€€",
  "address": {
    "@type": "PostalAddress",
    ...(streetAddress && { "streetAddress": streetAddress }),
    "addressLocality": location,
    ...(postalCode && { "postalCode": postalCode }),
    "addressRegion": "España",
    "addressCountry": "ES"
  },
  ...(openingHours && { "openingHoursSpecification": openingHours }),
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": String(avgRating),
    "bestRating": "5",
    "worstRating": "1",
    "ratingCount": String(reviewCount)
  }
};

if (geo) {
  structuredData["geo"] = {
    "@type": "GeoCoordinates",
    "latitude": geo.lat,
    "longitude": geo.lng
  };
  structuredData["hasMap"] = `https://www.google.com/maps?q=${geo.lat},${geo.lng}`;
}

import '@/styles/global.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={metaDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`https://${domain}${ogImage}`} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content={name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={`https://${domain}${ogImage}`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/usafitness.svg" />
    <link rel="apple-touch-icon" href="/usafitness.svg" />
    <title>{pageTitle}</title>

    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <main>
      <slot />
    </main>
  </body>
</html>
